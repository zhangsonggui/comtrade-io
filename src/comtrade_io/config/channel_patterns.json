{
  "analog_channel_type_patterns": [
    {
      "type": "A",
      "patterns": [
        ".*[Uu]a.*|.*[Uu]b.*|.*[Uu]c.*|.*[Uu]n.*|.*3[Uu]0.*|.*[Uu][Ll].*",
        ".*[Ii]a.*|.*[Ii]b.*|.*[Ii]c.*|.*[Ii]n.*|.*3[Ii]0.*|.*[Ii]0.*",
        ".*电压.*|.*电流.*|.*PT.*",
        ".*高频.*|.*频率曲线.*",
        "^U\\d+.*|^I\\d+.*",
        "^\\d+.*[Uu].*|^\\d+.*[Ii].*",
        ".*相电压.*|.*线电压.*|.*相电流.*|.*零序.*"
      ],
      "description": "交流通道：包含电压/电流标识（U/I）或中文'电压'/'电流'"
    },
    {
      "type": "D",
      "patterns": [
        "^\\+\\d+.*|^\\-\\d+.*",
        ".*\\+.*|.*\\-.*",
        "^DC\\d+.*|^dc\\d+.*",
        "^\\+110V.*|^\\-110V.*|^\\+220V.*|^\\-220V.*",
        "^\\+48V.*|^\\-48V.*|^\\+24V.*|^\\-24V.*",
        ".*直流.*|.*控制电源.*|.*操作电源.*",
        "^控制电源\\+.*|^控制电源\\-.*",
        "^.*\\+.*直流.*|^.*\\-.*直流.*",
        "^直.*"
      ],
      "description": "直流通道：包含+/-符号、直流标识或电压值"
    },
    {
      "type": "O",
      "patterns": [
        ".*模拟量.*|.*模拟通道.*"
      ],
      "description": "其他通道：模拟量通道等"
    }
  ],
  "analog_channel_flag_patterns": [
    {
      "flag": "HF",
      "patterns": [
        ".*高频.*|.*载波.*|.*收信.*|.*发信.*",
        "^HF.*|^hf.*"
      ],
      "description": "高频：高频通道相关标识",
      "priority": 15
    },
    {
      "flag": "FQ",
      "patterns": [
        ".*频率曲线.*",
        "^f$|^F$",
        "^f\\d+.*|^F\\d+.*",
        ".*_f$|.*_F$"
      ],
      "description": "频率：频率曲线标识或f单字母",
      "priority": 20
    },
    {
      "flag": "CONST",
      "patterns": [
        ".*直流.*|.*控制电源.*|.*操作电源.*",
        ".*\\+.*|.*\\-.*"
      ],
      "description": "常量：直流通道或常量标识",
      "priority": 12
    },
    {
      "flag": "ACC",
      "patterns": [
        ".*[Ii]a.*|.*[Ii]b.*|.*[Ii]c.*|.*[Ii]n.*|.*3[Ii]0.*|.*[Ii]0.*",
        ".*电流.*",
        "^I\\d+.*",
        ".*相电流.*|.*零序电流.*|.*中性点.*|.*间隙.*",
        "^\\d+.*[Ii].*",
        ".*[Ii].*[ABCN].*",
        "^.*_[Ii][ABCN].*$"
      ],
      "description": "电流：包含I或电流标识",
      "priority": 10
    },
    {
      "flag": "ACV",
      "patterns": [
        ".*[Uu]a.*|.*[Uu]b.*|.*[Uu]c.*|.*[Uu]n.*|.*3[Uu]0.*|.*[Uu][Ll].*",
        ".*电压.*|.*PT.*",
        "^U\\d+.*",
        ".*相电压.*|.*线电压.*|.*母线电压.*",
        "^\\d+.*[Uu].*",
        ".*[Uu].*[ABCN0].*",
        "^.*_[Uu][ABCN0].*$",
        ".*0$"
      ],
      "description": "电压：包含U或电压标识",
      "priority": 10
    },
    {
      "flag": "AG",
      "patterns": [
        ".*相位.*|.*角度.*|.*angle.*|.*ANGLE.*",
        "^AG.*|^ag.*"
      ],
      "description": "相位：相位或角度标识",
      "priority": 8
    },
    {
      "flag": "AMP",
      "patterns": [
        ".*幅值.*|.*magnitude.*|.*MAG.*",
        "^AMP.*|^amp.*"
      ],
      "description": "幅值：幅值标识",
      "priority": 8
    },
    {
      "flag": "PW",
      "patterns": [
        ".*功率.*|.*有功.*|.*无功.*|.*视在.*",
        ".*P.*|.*Q.*|.*S.*",
        "^P$|^Q$|^S$"
      ],
      "description": "功率：功率相关标识",
      "priority": 8
    },
    {
      "flag": "ZX",
      "patterns": [
        ".*阻抗.*|.*impedance.*|.*IMP.*|.*Z.*",
        "^ZX.*|^zx.*"
      ],
      "description": "阻抗：阻抗标识",
      "priority": 8
    },
    {
      "flag": "CONST",
      "patterns": [
        ".*常量.*|.*常数.*|.*constant.*|.*CONST.*",
        "^.*[0-9]+V$",
        "^定值.*"
      ],
      "description": "常量：常量或定值标识",
      "priority": 5
    }
  ],
  "default_values": {
    "type": "A",
    "flag": "ACC"
  }
}
